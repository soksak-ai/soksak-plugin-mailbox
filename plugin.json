{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-mailbox",
  "name": {
    "ko": "\uba54\uc2dc\uc9c0\ud568",
    "en": "Mailbox"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\ud504\ub85c\uc81d\ud2b8\ubcc4 \uba54\uc2dc\uc9c0\ud568 \u2014 CLI/MCP/API \ub85c \uba54\uc2dc\uc9c0\ub97c \ubcf4\ub0b4\uace0, \ud478\uc2dc \uc54c\ub9bc(\uc18c\ub9ac\u00b7\ub525\ub9c1\ud06c\u00b7\uc774\ubbf8\uc9c0)\uc73c\ub85c \ubc1b\ub294\ub2e4. '\uc2a4\uc2a4\ub85c \uad6c\ub3c5'\ud558\uba74 \ud134 \uc885\ub8cc \uc2dc \uae30\uacc4\uc801\uc73c\ub85c \uba54\uc2dc\uc9c0\ub97c \ubc1b\ub294\ub2e4. \uc88c\uce21 \uc0ac\uc774\ub4dc\ubc14 \ud0ed\uc5d0 \uc77d\uc9c0\uc54a\uc74c \ud45c\uc2dc.",
    "en": "Per-project message inbox \u2014 send messages via CLI/MCP/API and receive them as push notifications (sound, deep-link, image). Self-subscribe to receive messages automatically at turn end. Unread badge shown on the left sidebar tab."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "commands:destructive",
    "data",
    "notify",
    "terminal:read"
  ],
  "contributes": {
    "views": [
      {
        "id": "inbox",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0\ud568",
          "en": "Mailbox"
        },
        "icon": "\ud83d\udcec",
        "placements": [
          "rail"
        ]
      }
    ],
    "commands": [
      {
        "name": "send",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \ubcf4\ub0b4\uae30",
          "en": "Send Message"
        }
      },
      {
        "name": "list",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \ubaa9\ub85d",
          "en": "List Messages"
        }
      },
      {
        "name": "search",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \uac80\uc0c9",
          "en": "Search Messages"
        }
      },
      {
        "name": "get",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \uc870\ud68c",
          "en": "Get Message"
        }
      },
      {
        "name": "open",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \uc5f4\uae30(\ub525\ub9c1\ud06c)",
          "en": "Open Message (Deep Link)"
        }
      },
      {
        "name": "mark-read",
        "title": {
          "ko": "\uc77d\uc74c \ud45c\uc2dc",
          "en": "Mark as Read"
        }
      },
      {
        "name": "delete",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \uc0ad\uc81c",
          "en": "Delete Message"
        },
        "danger": "destructive"
      },
      {
        "name": "clear",
        "title": {
          "ko": "\uba54\uc2dc\uc9c0 \ube44\uc6b0\uae30",
          "en": "Clear Messages"
        },
        "danger": "destructive"
      },
      {
        "name": "subscribe",
        "title": {
          "ko": "\uc790\ub3d9 \uad6c\ub3c5 \ucf1c\uae30",
          "en": "Enable Auto-Subscribe"
        }
      },
      {
        "name": "unsubscribe",
        "title": {
          "ko": "\uc790\ub3d9 \uad6c\ub3c5 \ub044\uae30",
          "en": "Disable Auto-Subscribe"
        }
      },
      {
        "name": "subscriptions",
        "title": {
          "ko": "\uad6c\ub3c5 \ubaa9\ub85d",
          "en": "List Subscriptions"
        }
      },
      {
        "name": "export",
        "title": {
          "ko": "\ub0b4\ubcf4\ub0b4\uae30",
          "en": "Export"
        }
      },
      {
        "name": "import",
        "title": {
          "ko": "\uac00\uc838\uc624\uae30",
          "en": "Import"
        },
        "danger": "destructive"
      }
    ],
    "nodes": [
      {
        "id": "search",
        "description": "\uac80\uc0c9 \uc785\ub825 \ud544\ub4dc"
      },
      {
        "id": "msg",
        "description": "\uba54\uc2dc\uc9c0 \ud589(\ud074\ub9ad \uc2dc \uc77d\uc74c \ud45c\uc2dc)"
      },
      {
        "id": "del",
        "description": "\uba54\uc2dc\uc9c0 \uc0ad\uc81c \ubc84\ud2bc"
      }
    ],
    "events": [
      "mailbox.message",
      "mailbox.read"
    ]
  }
}
